# ============================================================
#  Variables d'environnement Supabase
#  Copier ce fichier en ".env" puis remplir avec les valeurs
#  de ton projet Supabase (Dashboard > Project Settings > API).
#  Le .env est lu automatiquement par "docker compose".
# ============================================================

# URL du projet Supabase (ex: https://abcdefgh.supabase.co)
SUPABASE_URL=

# Clé publique "anon" (Project Settings > API > Project API keys > anon public)
# Utilisée par auth-service pour appeler l'API d'auth Supabase.
SUPABASE_ANON_KEY=

# Secret JWT du projet (Project Settings > API > JWT Settings > JWT Secret)
# Utilisé par node-api pour VÉRIFIER les tokens émis par Supabase.
SUPABASE_JWT_SECRET=
